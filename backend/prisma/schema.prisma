// ===== Esquema de Base de Datos — Sistema HSE =====
// Versión 3.0 — Sucursal expandida: SUNAFIL / INDECI / Ley 29783
// Cada modelo y campo está documentado en español

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===== ENUMS =====

enum Rol {
  COORDINADOR // Administrador del sistema HSE
  SUPERVISOR // Usuario de campo
  JEFATURA // Solo lectura, dashboards
}

enum EstadoLaboral {
  ACTIVO
  CESADO
}

enum EstadoEMO {
  APTO
  NO_APTO
  APTO_RESTRICCION
}

/// FASE 2: Tipo de examen médico para el historial EMO normalizado
enum TipoExamenMedico {
  INGRESO // Examen al ingresar a la empresa
  PERIODICO // Examen de control anual
  RETIRO // Examen al cesar relación laboral
  REINTEGRO // Examen al reincorporarse de incapacidad
}

enum EstadoEquipo {
  OPERATIVO
  EN_MANTENIMIENTO
  BLOQUEADO_CERTIFICADO // Bloqueado automáticamente por CRON — certificación vencida
  BLOQUEADO_INSPECCION // Bloqueado automáticamente por falla crítica en checklist pre-uso
  BAJA_TECNICA
}

enum SeveridadFalta {
  LEVE
  GRAVE
  CRITICA
}

enum EstadoInspeccion {
  EN_PROGRESO
  COMPLETADA
  CANCELADA
}

/// Tipo de instalación según clasificación INDECI / Ley 29783
enum TipoInstalacion {
  OFICINA
  PLANTA_INDUSTRIAL
  ALMACEN
  LABORATORIO
  OBRA
}

/// Nivel de riesgo operacional / SST de la sede
enum NivelRiesgo {
  BAJO
  MEDIO
  ALTO
  CRITICO
}

/// Categoría de riesgo de incendio (NFPA / NTP 350.043)
enum CategoriaIncendio {
  BAJO
  ORDINARIO
  ALTO
}

/// Resultado de la última inspección SUNAFIL
enum ResultadoInspeccionSUNAFIL {
  CONFORME // Sin observaciones
  OBSERVADO // Con observaciones subsanables
  NO_CONFORME // Incumplimiento formal
  SANCIONADO // Multa / medida cautelar impuesta
}

/// Clasificación de maquinaria para trazabilidad legal (DS 024-2016-EM / ISO 45001)
enum TipoEquipo {
  MAQUINARIA_PESADA // Grúas, excavadoras, montacargas, palas mecánicas
  HERRAMIENTA_PODER // Esmeriles, taladros, sierras circulares, rotomartillos
  EQUIPO_MEDICION // Manómetros, termómetros, baumanómetros (requieren calibración INACAL)
  VEHICULO // Camionetas, cisternas, volquetes, ambulancias
  EQUIPO_PRESION // Compresoras, autoclaves, calderas (requieren ASME)
  HERRAMIENTA_MENOR // Herramientas manuales bajo clasificación de riesgo
}

/// Estado de autorización de un operador para usar un equipo específico
enum EstadoAutorizacion {
  PENDIENTE // Sin revisión formal aún
  AUTORIZADO // Capacitación y EMO verificados — acceso habilitado
  SUSPENDIDO // EMO vencido o capacitación caducada — acceso revocado temporalmente
  REVOCADO // Baja definitiva de la autorización
}

/// Tipo de intervención técnica sobre el equipo
enum TipoMantenimiento {
  PREVENTIVO // Programado por calendario u horas operadas
  CORRECTIVO // En respuesta a una falla detectada
  PREDICTIVO // Basado en análisis de condición (vibraciones, temperatura)
  OVERHAUL // Reparación general mayor
}

/// Resultado de calibración según INACAL / NTP-ISO/IEC 17025
enum EstadoCalibracion {
  CONFORME // Dentro de especificaciones — aprobado
  NO_CONFORME // Fuera de especificaciones — requiere ajuste o baja inmediata
  CONDICIONADO // Apto con restricciones operativas documentadas
}

/// Clasificación de la inspección para trazabilidad legal diferenciada
enum TipoInspeccion {
  GENERAL // Inspección de área, ambiente o SST general
  PRE_USO // Verificación obligatoria pre-turno de un equipo (DS 024-2016-EM Art. 238)
  PERIODICA // Inspección programada mensual / trimestral del equipo
  POST_INCIDENTE // Obligatoria tras cualquier evento o accidente con el equipo
}

/// Estado de ejecución de un procedimiento LOTO (Bloqueo y Etiquetado — OSHA 1910.147)
enum EstadoLoto {
  BLOQUEADO // Energías aisladas — equipo bajo intervención segura
  DESBLOQUEADO // Energías restauradas — equipo devuelto al servicio
  INCIDENCIA // Se reportó un problema durante el procedimiento de bloqueo
}

// ===== USUARIOS DEL SISTEMA =====

model Usuario {
  id             String    @id @default(uuid())
  correo         String    @unique
  contrasena     String // Hash bcrypt
  nombreCompleto String
  rol            Rol
  activo         Boolean   @default(true)
  creadoEn       DateTime  @default(now())
  actualizadoEn  DateTime  @updatedAt
  // FASE 1 — Soft-Delete: permite auditoría SUNAFIL sin pérdida de historial
  deletedAt      DateTime? // null = activo | fecha = eliminado lógicamente

  // Relaciones
  supervisor        Supervisor?
  registrosAudit    RegistroAuditoria[]
  notificaciones    Notificacion[]
  documentosSubidos DocumentoEquipo[]   @relation("DocumentosSubidos")
  dossierExports    DossierExportLog[]  @relation("DossierExports")

  @@index([activo])
  @@index([deletedAt])
  @@map("usuarios")
}

// ===== MÓDULO 1: BASE DE DATOS MAESTRA =====

model Sucursal {
  id            String    @id @default(uuid())
  nombre        String    @unique
  direccion     String?
  latitud       Float?
  longitud      Float?
  activa        Boolean   @default(true)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt
  // Soft-Delete: sede dada de baja lógicamente, historial preservado
  deletedAt     DateTime?

  // ─── CLASIFICACIÓN DE LA INSTALACIÓN (INDECI / Ley 29783) ───────────────
  tipoInstalacion   TipoInstalacion? // Tipo de establecimiento
  nivelRiesgo       NivelRiesgo? // Nivel de riesgo SST declarado
  categoriaIncendio CategoriaIncendio? // Riesgo de incendio NFPA

  // ─── DATOS LEGALES Y REGISTROS OBLIGATORIOS ──────────────────────────────
  // Clasificación Industrial Internacional Uniforme (SBS / SUNAT)
  codigoCIIU                  String?
  // Código de establecimiento en el Registro Nacional INDECI
  codigoEstablecimientoINDECI String?   @unique
  // N° de Certificado de Inspección de Defensa Civil
  numeroCertificadoDC         String?
  vencimientoCertificadoDC    DateTime? // Fecha de vencimiento del certificado DC
  fechaProximaRevisionDC      DateTime? // Próxima revisión programada

  // ─── INFRAESTRUCTURA FÍSICA ───────────────────────────────────────────────
  aforoMaximo       Int? // Capacidad máxima de personas (INDECI)
  areaM2            Float? // Área total del establecimiento en m²
  numeroPisos       Int? // Número de pisos / niveles
  anioConstruccion  Int? // Año de construcción (evaluación sísmica)
  zonaRiesgoSismico Int? // Zona sísmica 1-4 según NTE E.030

  // ─── GESTIÓN DE EMERGENCIAS (Ley 29783 Art. 34) ──────────────────────────
  // Responsable SST de la sede
  responsableSSTNombre    String?
  responsableSSTTelefono  String?
  // Servicio médico
  medicoOcupacionalNombre String?
  centroMedicoMasCercano  String?
  telefonoCentroMedico    String?
  // Equipamiento de emergencias
  cantidadExtintores      Int?    @default(0)
  tieneDesfibriladorDEA   Boolean @default(false)
  ubicacionDEA            String? // Descripción de la ubicación del DEA
  cantidadBotiquines      Int?    @default(0)
  tieneEnfermeria         Boolean @default(false)
  telefonoEmergenciasSede String? // Línea directa de emergencias de la sede

  // ─── PLAN DE EMERGENCIA Y SIMULACROS ─────────────────────────────────────
  planEmergenciaVigente          Boolean   @default(false)
  fechaVencimientoPlanEmergencia DateTime?
  fechaUltimoSimulacro           DateTime?
  cantidadSimulacrosAnio         Int?      @default(0)

  // ─── BRIGADAS Y PELIGROS (JSONB) ─────────────────────────────────────────
  // Estructura ejemplo brigadasEmergencia:
  // [{"tipo":"Evacuación","jefe":"Juan Pérez","miembros":4,"certificado":true}]
  brigadasEmergencia    Json? // JSONB: Array de brigadas con roles y certificaciones
  // Estructura ejemplo peligrosIdentificados:
  // [{"tipo":"Eléctrico","nivel":"ALTO","zona":"Sala de servidores","control":"Extintores CO2"}]
  peligrosIdentificados Json? // JSONB: Mapa de peligros identificados por zona

  // ─── TRAZABILIDAD SUNAFIL ─────────────────────────────────────────────────
  fechaUltimaInspeccionSUNAFIL DateTime?
  resultadoUltimaInspeccion    ResultadoInspeccionSUNAFIL?
  observacionesLegalesActivas  String? // Observaciones / multas pendientes de subsanar

  // Relaciones
  trabajadores   Trabajador[]
  supervisores   SupervisorSucursal[]
  inspecciones   Inspeccion[]
  amonestaciones Amonestacion[]
  equipos        Equipo[] // FASE 3 — Equipos físicamente ubicados en esta sucursal

  // Índices B-tree para alertas diarias y dashboards legales
  @@index([activa])
  @@index([deletedAt])
  @@index([tipoInstalacion])
  @@index([nivelRiesgo])
  @@index([vencimientoCertificadoDC]) // Alerta: certificados DC próximos a vencer
  @@index([fechaProximaRevisionDC]) // Alerta: revisiones DC programadas
  @@index([resultadoUltimaInspeccion]) // Dashboard: sedes con observaciones SUNAFIL
  @@index([planEmergenciaVigente])
  @@map("sucursales")
}

model Trabajador {
  id                 String  @id @default(uuid())
  dni                String  @unique // Indexed por @unique — clave de búsqueda QR
  nombreCompleto     String
  cargo              String
  tipoSangre         String?
  telefonoEmergencia String?
  contactoEmergencia String?

  // FASE 2 — Cache del último estado EMO (actualizado por trigger de negocio)
  // El historial completo vive en ExamenMedico
  estadoEMO           EstadoEMO     @default(APTO)
  fechaVencimientoEMO DateTime?
  estadoLaboral       EstadoLaboral @default(ACTIVO)

  // Tallas de EPP
  tallaCasco    String?
  tallaCamisa   String?
  tallaPantalon String?
  tallaCalzado  String?
  tallaGuantes  String?

  // Código QR único
  codigoQr String? @unique

  // Foto de perfil (URL o Base64 Data URI)
  fotoUrl String?

  // Datos médicos de acceso rápido (escáner QR emergencias)
  alergiasCriticas         String?
  condicionesPreexistentes String?
  eps                      String? // Entidad Prestadora de Salud
  arl                      String? // Administradora de Riesgos Laborales
  fechaUltimoExamen        DateTime?

  // Datos auxiliares del trabajador
  fechaIngreso    DateTime?
  fechaNacimiento DateTime?
  curp            String?
  nss             String?
  telefono        String?
  correo          String?
  turno           String?
  nivelEducativo  String?

  sucursalId    String
  activo        Boolean   @default(true)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt
  // FASE 1 — Soft-Delete: historial laboral protegido para SUNAFIL
  deletedAt     DateTime?

  // Relaciones
  sucursal        Sucursal?              @relation(fields: [sucursalId], references: [id], onDelete: Restrict)
  entregasEpp     EntregaEpp[]
  capacitaciones  Capacitacion[]
  amonestaciones  Amonestacion[]
  incidentes      Incidente[]
  inspecciones    InspeccionTrabajador[]
  // FASE 2 — Historial médico normalizado (uno-a-muchos)
  examenesMedicos ExamenMedico[]
  // FASE 3 — Autorizaciones para operar equipos específicos
  autorizaciones  AutorizacionOperador[]
  ejecucionesLoto EjecucionLoto[]

  // FASE 2 — Índices para búsqueda rápida en escáner QR de emergencias
  @@index([sucursalId])
  @@index([estadoLaboral])
  @@index([tipoSangre]) // Emergencias: filtro rápido por tipo de sangre
  @@index([activo])
  @@index([deletedAt])
  @@map("trabajadores")
}

model Supervisor {
  id            String   @id @default(uuid())
  usuarioId     String   @unique
  telefono      String?
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  // Relaciones
  usuario        Usuario              @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  sucursales     SupervisorSucursal[]
  inspecciones   Inspeccion[]
  amonestaciones Amonestacion[]

  @@map("supervisores")
}

model SupervisorSucursal {
  id           String @id @default(uuid())
  supervisorId String
  sucursalId   String

  supervisor Supervisor @relation(fields: [supervisorId], references: [id], onDelete: Cascade)
  sucursal   Sucursal   @relation(fields: [sucursalId], references: [id], onDelete: Cascade)

  @@unique([supervisorId, sucursalId])
  @@map("supervisor_sucursal")
}

model Equipo {
  id            String       @id @default(uuid())
  nombre        String
  marca         String?
  modelo        String?
  numeroSerie   String       @unique
  nfcTagId      String?      @unique
  estado        EstadoEquipo @default(OPERATIVO)
  descripcion   String?
  manualUrl     String?
  creadoEn      DateTime     @default(now())
  actualizadoEn DateTime     @updatedAt
  // FASE 1 — Soft-Delete: el equipo dado de baja mantiene historial de calibraciones
  deletedAt     DateTime?

  // ─── SINERGIA — Ubicación física (OBLIGATORIO) ────────────────────────────
  sucursalId      String? // FK Sucursal — MIGRACIÓN FASE 1: nullable. Poblar y luego forzar NOT NULL.
  ubicacionFisica String? // Ej: "Almacén Zona Norte - Rack 3 / Piso 2"

  // ─── CICLO DE VIDA (DS 024-2016-EM / ISO 45001) ───────────────────────────
  tipoEquipo               TipoEquipo @default(HERRAMIENTA_MENOR) // Clasificación legal — revisar por equipo
  fechaFabricacion         DateTime? // Para calcular vida útil real vs. declarada
  fechaAdquisicion         DateTime? // Fecha de alta formal en la empresa
  vidaUtilMeses            Int? // Límite operacional declarado por fabricante
  proximoMantenimiento     DateTime? // Fecha programada del siguiente mantenimiento
  horasOperadasActuales    Float? // Contador de horas (para mantenimiento por horas)
  horasLimiteMantenimiento Float? // Umbral que dispara alerta preventiva

  // ─── PROTOCOLO LOTO (OSHA 1910.147 / Reglamento Seg. Industrial Perú) ────
  requiereLoto       Boolean  @default(false) // Maquinaria con energía peligrosa
  puntosBloqueo      String? // "3 disyuntores panel A, 1 válvula hidráulica 150 bar"
  energiasPeligrosas String[] // ["ELECTRICA_480V", "HIDRAULICA_150BAR", "NEUMATICA"]

  // ─── EPP OBLIGATORIO POR MÁQUINA (JSONB) ─────────────────────────────────
  // Estructura: [{"tipo":"CASCO","especificacion":"Clase E","obligatorio":true}, ...]
  eppObligatorio Json? // Lista de EPP requeridos para operar este equipo específico

  // ─── RESPONSABLE HSE Y DATOS TÉCNICOS LEGALES (Auditoría HSE - Marzo 2026) ──
  // DS 005-2012-TR Art. 26 lit. f): identificar al responsable de seguridad
  coordinadorResponsable        String? // Nombre del coordinador HSE asignado a este equipo
  telefonoEmergenciaCoordinador String? // Teléfono de emergencia del coordinador HSE
  // DS 042-F / ASME VIII: capacidad nominal o presión máxima de trabajo declarada
  capacidadNominalPresion       String? // Ej: "150 BAR", "5 Ton", "1200 RPM"

  // ─── BLOQUEO AUTOMÁTICO DEL SISTEMA (CRON / Regla de negocio) ────────────
  esBloqueoAutomatico Boolean   @default(false) // true = estado cambiado por CRON o regla automática
  motivoBloqueoAuto   String? // Ej: "Certificación INACAL vencida el 2026-03-01"
  fechaBloqueoAuto    DateTime? // Timestamp del bloqueo automático

  // ─── VÍNCULO CON MATRIZ IPC (Pestaña 1 — Matriz de Riesgos) ─────────────
  matrizIpcId String? // FK a MatrizIpc — muestra la matriz de riesgos del equipo

  // Relaciones
  sucursal        Sucursal?              @relation(fields: [sucursalId], references: [id], onDelete: Restrict)
  matrizIpc       MatrizIpc?             @relation(fields: [matrizIpcId], references: [id], onDelete: SetNull)
  calibraciones   Calibracion[]
  mantenimientos  Mantenimiento[]
  autorizaciones  AutorizacionOperador[]
  ejecucionesLoto EjecucionLoto[]
  inspecciones    Inspeccion[]
  dossierLogs     DossierExportLog[]
  documentos      DocumentoEquipo[]

  @@index([estado])
  @@index([sucursalId]) // Filtrar equipos por sede
  @@index([tipoEquipo]) // Clasificar para auditorías
  @@index([deletedAt])
  @@index([proximoMantenimiento]) // Alertas de mantenimiento próximo
  @@index([estado, esBloqueoAutomatico]) // Dashboard de bloqueados automáticos
  @@index([matrizIpcId])
  @@map("equipos")
}

model Calibracion {
  id                 String   @id @default(uuid())
  equipoId           String
  fechaCalibracion   DateTime
  proximaCalibracion DateTime
  certificadoUrl     String? // Ruta al certificado digital (INACAL)
  observaciones      String?
  creadoEn           DateTime @default(now())

  // ─── CAMPOS INACAL / NTP-ISO/IEC 17025 (requeridos para validez legal) ────
  // MIGRACIÓN FASE 1: nullable para registros históricos. Nuevas calibraciones deben incluirlo.
  entidadCertificadora     String? // "INACAL", "SGS", "Bureau Veritas" — requerido en nuevas altas
  numeroCertificado        String? // N° de serie del certificado (trazabilidad INACAL)
  estadoResultado          EstadoCalibracion @default(CONFORME) // ¿El equipo pasó la calibración?
  // NTP-ISO/IEC 17025: N° de acreditación del laboratorio calibrador ante INACAL
  // Sin este campo, el certificado carece de trazabilidad legal ante SUNAFIL/Metrología.
  numeroAcreditacionInacal String? // Ej: "LE-038", "LC-047" — emitido por INACAL

  // Relaciones
  equipo Equipo @relation(fields: [equipoId], references: [id], onDelete: Restrict) // SEC: Historial de calibraciones es inmutable

  @@index([equipoId])
  @@index([proximaCalibracion]) // Alertas de vencimiento
  @@index([estadoResultado]) // Filtrar equipos con calibración no conforme
  @@map("calibraciones")
}

// ===== MATRIZ IPC =====

model MatrizIpc {
  id                       String   @id @default(uuid())
  cargo                    String
  ubicacion                String
  eppsObligatorios         Json // JSONB: Array de EPPs requeridos
  herramientasRequeridas   Json // JSONB: Array de herramientas
  capacitacionesRequeridas Json // JSONB: Array de capacitaciones
  descripcion              String?
  activo                   Boolean  @default(true)
  creadoEn                 DateTime @default(now())
  actualizadoEn            DateTime @updatedAt

  // Relaciones
  equipos Equipo[] // Equipos vinculados a esta matriz de riesgos (Pestaña 1)

  @@unique([cargo, ubicacion])
  @@index([cargo]) // Búsqueda por puesto de trabajo
  @@index([activo])
  // FASE 3 — GIN indexes sobre JSONB (eppsObligatorios, herramientasRequeridas,
  // capacitacionesRequeridas) aplicados vía SQL raw en la migración:
  // CREATE INDEX idx_matriz_epps_gin ON matriz_ipc USING gin("eppsObligatorios");
  // CREATE INDEX idx_matriz_herramientas_gin ON matriz_ipc USING gin("herramientasRequeridas");
  // CREATE INDEX idx_matriz_capacitaciones_gin ON matriz_ipc USING gin("capacitacionesRequeridas");
  @@map("matriz_ipc")
}

// ===== MÓDULO 2: PERFIL 360° (ENTREGAS Y CAPACITACIONES) =====

// FASE 2 — Tabla normalizada de Exámenes Médicos Ocupacionales (EMO)
// Permite historial completo de aptitudes a lo largo de los años.
// El campo estadoEMO/fechaVencimientoEMO en Trabajador funciona como cache.
model ExamenMedico {
  id                 String           @id @default(uuid())
  trabajadorId       String
  tipoExamen         TipoExamenMedico
  fechaExamen        DateTime
  estado             EstadoEMO
  restricciones      String? // Ej: "No trabajo en altura por 6 meses"
  observaciones      String?
  medicoEvaluador    String?
  institucion        String? // Clínica o centro de salud
  documentoUrl       String? // URL al certificado/informe médico
  proximoVencimiento DateTime? // Fecha del próximo examen requerido
  creadoEn           DateTime         @default(now())

  // Relaciones — onDelete Restrict: historial médico es prueba legal inmutable
  trabajador Trabajador @relation(fields: [trabajadorId], references: [id], onDelete: Restrict)

  @@index([trabajadorId])
  @@index([fechaExamen])
  @@index([estado])
  @@index([proximoVencimiento]) // Para alertas de vencimiento próximo
  @@map("examenes_medicos")
}

model EntregaEpp {
  id               String    @id @default(uuid())
  trabajadorId     String
  tipoEpp          String // Ej: "Casco dieléctrico", "Arnés"
  marca            String?
  talla            String?
  fechaEntrega     DateTime
  fechaVencimiento DateTime?
  observaciones    String?
  creadoEn         DateTime  @default(now())

  // Relaciones
  trabajador Trabajador @relation(fields: [trabajadorId], references: [id], onDelete: Restrict) // SEC: Historial de EPP es inmutable (Expediente 360°)

  @@map("entregas_epp")
}

model Capacitacion {
  id               String    @id @default(uuid())
  trabajadorId     String
  nombreCurso      String // Ej: "Trabajo en altura", "Riesgo eléctrico"
  institucion      String?
  fechaRealizacion DateTime
  fechaVencimiento DateTime?
  certificadoUrl   String?
  vigente          Boolean   @default(true)
  creadoEn         DateTime  @default(now())

  // Relaciones
  trabajador Trabajador @relation(fields: [trabajadorId], references: [id], onDelete: Restrict) // SEC: Certificaciones son inmutables (Expediente 360°)

  @@map("capacitaciones")
}

// ===== MÓDULO 3: INSPECCIONES =====

model Inspeccion {
  id           String           @id @default(uuid())
  supervisorId String
  sucursalId   String
  ubicacion    String // Zona específica del trabajo
  tipoTrabajo  String // Ej: "Trabajo en Altura", "Excavación"
  estado       EstadoInspeccion @default(EN_PROGRESO)

  // ─── SINERGIA CON EQUIPOS (FASE 3) ───────────────────────────────────────
  // Opcional: una inspección puede ser GENERAL (sin equipo) o PRE_USO/PERIODICA (con equipo)
  equipoId       String? // FK opcional — vincula la inspección a un equipo específico
  tipoInspeccion TipoInspeccion @default(GENERAL)

  // Checklist dinámico generado desde la Matriz IPC
  checklist     Json // JSONB: items del checklist con sus estados
  observaciones String?

  // Cierre
  firmaSupervisor Boolean   @default(false)
  firmaBase64     String? // Almacena la imagen base64 de la firma
  latitudCierre   Float?
  longitudCierre  Float?
  fechaCierre     DateTime?

  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt
  // FASE 1 — Soft-Delete: el acta de inspección es un documento legal firmado.
  // Nunca se elimina físicamente; se marca como anulada con fecha y motivo en `observaciones`.
  deletedAt     DateTime?

  // Relaciones
  supervisor   Supervisor             @relation(fields: [supervisorId], references: [id], onDelete: Restrict)
  sucursal     Sucursal               @relation(fields: [sucursalId], references: [id], onDelete: Restrict)
  equipo       Equipo?                @relation(fields: [equipoId], references: [id], onDelete: SetNull)
  fotos        FotoInspeccion[]
  trabajadores InspeccionTrabajador[]

  @@index([estado])
  @@index([tipoInspeccion]) // Filtrar por PRE_USO, PERIODICA, POST_INCIDENTE
  @@index([equipoId]) // Historial de inspecciones por equipo
  @@index([deletedAt])
  @@map("inspecciones")
}

model InspeccionTrabajador {
  id           String @id @default(uuid())
  inspeccionId String
  trabajadorId String

  inspeccion Inspeccion @relation(fields: [inspeccionId], references: [id], onDelete: Cascade)
  trabajador Trabajador @relation(fields: [trabajadorId], references: [id], onDelete: Restrict)

  @@unique([inspeccionId, trabajadorId])
  @@map("inspeccion_trabajador")
}

model FotoInspeccion {
  id           String   @id @default(uuid())
  inspeccionId String
  rutaArchivo  String
  descripcion  String?
  fechaCaptura DateTime @default(now())
  metadatos    Json? // JSONB: fecha, hora, dispositivo

  // Relaciones
  inspeccion Inspeccion @relation(fields: [inspeccionId], references: [id], onDelete: Cascade)

  @@map("fotos_inspeccion")
}

// ===== MÓDULO 4: AMONESTACIONES E INCIDENTES =====

model Amonestacion {
  id           String @id @default(uuid())
  trabajadorId String
  supervisorId String
  sucursalId   String

  motivo      String // Ej: "No uso de EPP", "Acto inseguro"
  severidad   SeveridadFalta
  descripcion String // Relatoría de los hechos
  testimonios String? // Testimonios breves

  fechaEvento   DateTime
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt
  // FASE 1 — Soft-Delete: sanción disciplinaria con valor jurídico ante SUNAFIL.
  // La amonestación nunca desaparece del sistema; solo se anula lógicamente.
  deletedAt     DateTime?

  // Relaciones
  trabajador Trabajador         @relation(fields: [trabajadorId], references: [id], onDelete: Restrict)
  supervisor Supervisor         @relation(fields: [supervisorId], references: [id], onDelete: Restrict)
  sucursal   Sucursal           @relation(fields: [sucursalId], references: [id], onDelete: Restrict)
  fotos      FotoAmonestacion[]
  incidentes Incidente[]

  @@index([trabajadorId])
  @@index([severidad])
  @@index([deletedAt])
  @@map("amonestaciones")
}

model FotoAmonestacion {
  id             String   @id @default(uuid())
  amonestacionId String
  rutaArchivo    String
  descripcion    String?
  fechaCaptura   DateTime @default(now())

  // Relaciones
  amonestacion Amonestacion @relation(fields: [amonestacionId], references: [id], onDelete: Cascade)

  @@map("fotos_amonestacion")
}

model Incidente {
  id             String    @id @default(uuid())
  trabajadorId   String
  amonestacionId String?
  descripcion    String
  ubicacion      String?
  fechaEvento    DateTime
  creadoEn       DateTime  @default(now())
  // FASE 1 — Soft-Delete: reporte de accidente/incidente obligatorio por Ley 29783.
  // Su eliminación física está prohibida; solo se puede anular con justificación.
  deletedAt      DateTime?

  // Relaciones
  trabajador     Trabajador      @relation(fields: [trabajadorId], references: [id], onDelete: Restrict)
  amonestacion   Amonestacion?   @relation(fields: [amonestacionId], references: [id], onDelete: SetNull)
  mantenimientos Mantenimiento[] // Relación inversa: mantenimientos que derivaron de este incidente

  @@index([trabajadorId])
  @@index([fechaEvento])
  @@index([deletedAt])
  @@map("incidentes")
}

// ===== MÓDULO 4b: GESTIÓN DE EQUIPOS — MODELOS NUEVOS =====

/// Tabla intermedia que autoriza a un Trabajador a operar un Equipo específico.
/// Regla de negocio: sin AUTORIZADO activo, el backend bloquea el registro de Pre-Uso.
model AutorizacionOperador {
  id                     String             @id @default(uuid())
  trabajadorId           String
  equipoId               String
  // Habilitadores que el Coordinador debe verificar antes de autorizar
  capacitacionRequerida  String // Ej: "Operación Montacargas OSHA 1910.178"
  capacitacionVerificada Boolean            @default(false)
  emoVigenteVerificado   Boolean            @default(false)
  eppVerificado          Boolean            @default(false)
  // Estado y vigencia de la autorización
  estado                 EstadoAutorizacion @default(PENDIENTE)
  fechaVencimiento       DateTime? // La autorización también caduca
  autorizadoPorId        String? // userId del Coordinador que aprueba
  observaciones          String?
  creadoEn               DateTime           @default(now())
  actualizadoEn          DateTime           @updatedAt

  trabajador Trabajador @relation(fields: [trabajadorId], references: [id], onDelete: Restrict)
  equipo     Equipo     @relation(fields: [equipoId], references: [id], onDelete: Restrict)

  // Un trabajador tiene una sola autorización activa por equipo
  @@unique([trabajadorId, equipoId])
  @@index([estado])
  @@index([fechaVencimiento]) // Alertas de autorización próxima a vencer
  @@map("autorizaciones_operador")
}

/// Registro de cada intervención técnica sobre un equipo.
/// Diferente a Calibracion: la calibración es metrológica; el mantenimiento es mecánico.
model Mantenimiento {
  id                   String            @id @default(uuid())
  equipoId             String
  tipoMantenimiento    TipoMantenimiento
  fechaMantenimiento   DateTime
  proximoMantenimiento DateTime? // Actualiza también el campo en Equipo
  tecnicoResponsable   String // Nombre del técnico o empresa ejecutora
  proveedorServicio    String? // Empresa contratista (si aplica)
  trabajoRealizado     String // Descripción técnica del trabajo ejecutado
  repuestosUsados      String? // Trazabilidad de repuestos (para análisis de vida útil)
  horasEquipoAlMomento Float? // Odómetro en horas al momento del servicio
  costoSoles           Float? // Para análisis costo-beneficio y presupuesto
  equipoFueraServicio  Boolean           @default(false) // ¿El equipo quedó fuera de servicio?
  equipoQuedoOperativo Boolean           @default(true) // ¿El equipo quedó operativo tras la intervención?
  certificadoUrl       String? // Orden de trabajo firmada / informe técnico — OBLIGATORIO en producción
  observaciones        String?
  creadoEn             DateTime          @default(now())

  // ─── CAMPOS HSE LEGALES — FASE 4 ─────────────────────────────────────────
  // OSHA 1910.147: Certificación de protocolo LOTO aplicado
  aplicoLoto           Boolean @default(false)
  // Ley 29783 Art. 82: Vinculación con reporte de incidente si la falla generó accidente
  generoIncidente      Boolean @default(false)
  incidenteId          String? // FK a Incidente — poblado si generoIncidente=true
  // DS 024-2016-EM: Certificación técnica del interventor
  certificacionTecnico String? // Ej: "NFPA 70E Arco Eléctrico", "ASME B31.3"
  // ISO 14001:2015 Cláusula 8.1: Gestión de residuos peligrosos generados
  disposicionResiduos  String? // Ej: "Aceites entregados a EPS-RS Mant. Industrial SAC"

  // Relaciones
  equipo    Equipo     @relation(fields: [equipoId], references: [id], onDelete: Restrict) // Historial inmutable
  incidente Incidente? @relation(fields: [incidenteId], references: [id], onDelete: SetNull)

  @@index([equipoId])
  @@index([tipoMantenimiento])
  @@index([fechaMantenimiento])
  @@index([generoIncidente]) // Dashboard: mantenimientos con incidentes asociados
  @@index([aplicoLoto]) // Auditoría de cumplimiento LOTO
  @@map("mantenimientos")
}

/// Registro de ejecución de procedimiento LOTO (Lockout/Tagout).
/// Obligatorio antes de cualquier mantenimiento en equipos con energía peligrosa.
/// Regla de negocio: si Equipo.requiereLoto=true, no se crea Mantenimiento sin LOTO activo.
model EjecucionLoto {
  id                String     @id @default(uuid())
  equipoId          String
  trabajadorId      String // Operario que instala el/los candado(s)
  motivoBloqueo     String // "Mantenimiento preventivo", "Limpieza interna", etc.
  autorizadoPorId   String? // userId del Supervisor que autoriza el bloqueo
  fechaBloqueo      DateTime
  fechaDesbloqueo   DateTime? // Null = candado activo actualmente
  // Checklist de verificación de energía cero (JSONB)
  // [{"paso":"Abrir disyuntor A-3","verificado":true}, {"paso":"Purgar presión hidráulica","verificado":true}]
  listaVerificacion Json
  estadoEjecucion   EstadoLoto @default(BLOQUEADO)
  observaciones     String?
  creadoEn          DateTime   @default(now())
  actualizadoEn     DateTime   @updatedAt

  equipo     Equipo     @relation(fields: [equipoId], references: [id], onDelete: Restrict)
  trabajador Trabajador @relation(fields: [trabajadorId], references: [id], onDelete: Restrict)

  @@index([equipoId])
  @@index([estadoEjecucion]) // Buscar rápidamente LOTO activos (BLOQUEADO)
  @@map("ejecuciones_loto")
}

// ===== MÓDULO 5: AUDIT LOG Y NOTIFICACIONES =====

model RegistroAuditoria {
  id        String   @id @default(uuid())
  usuarioId String
  accion    String // Ej: "CREAR_TRABAJADOR", "EDITAR_INSPECCION"
  entidad   String // Ej: "Trabajador", "Inspeccion"
  entidadId String?
  detalles  Json? // JSONB: datos adicionales del cambio
  ip        String?
  creadoEn  DateTime @default(now())

  // Relaciones
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Restrict) // SEC: Audit Trail inmutable (Trazabilidad Absoluta PRD §5)

  // FASE 3 — Índices para consultas rápidas de audit trail y dashboard
  @@index([usuarioId])
  @@index([entidad, entidadId]) // Filtro: todos los cambios de un registro específico
  @@index([creadoEn]) // Para particionamiento lógico por mes en el dashboard
  @@map("registros_auditoria")
}

model Notificacion {
  id              String   @id @default(uuid())
  destinatarioId  String
  tipo            String // Ej: "FALTA_CRITICA", "VENCIMIENTO_CALIBRACION"
  titulo          String
  mensaje         String
  leida           Boolean  @default(false)
  enviadaPorEmail Boolean  @default(false)
  creadoEn        DateTime @default(now())

  // Relaciones
  destinatario Usuario @relation(fields: [destinatarioId], references: [id], onDelete: Cascade)

  @@map("notificaciones")
}

// ===== MÓDULO 4c: TRAZABILIDAD DE EXPORTACIONES Y DOCUMENTOS =====

/// Tipos de documento técnico/legal vinculados a un equipo.
enum TipoDocumentoEquipo {
  MANUAL_FABRICANTE // Manual de operación oficial del fabricante
  NORMA_APLICABLE // Norma ISO, ASME, OSHA referenciada
  CERTIFICADO_FABRICACION // Certificado de fabricación y primera puesta en marcha
  CERTIFICADO_PRUEBA_CARGA // Para equipos de izaje (grúas, eslingas) — ASME B30
  FICHA_TECNICA // Especificaciones técnicas resumidas
  PROCEDIMIENTO_LOTO // Procedimiento LOTO específico del equipo (OSHA 1910.147)
  LISTA_REPUESTOS // Catálogo de repuestos del fabricante
  OTRO
}

/// Repositorio de documentos técnico-legales vinculados a un equipo.
/// Soporta la Pestaña 4 (Certificaciones y Manuales) del Expediente 360°.
model DocumentoEquipo {
  id               String              @id @default(uuid())
  equipoId         String
  nombre           String // Ej: "Manual de Operación v2.3"
  tipo             TipoDocumentoEquipo
  archivoUrl       String // URL a S3 / Azure Blob
  version          String? // Ej: "Rev. 3"
  emitidoPor       String? // Fabricante, INACAL, SUNAFIL, etc.
  fechaEmision     DateTime?
  fechaVencimiento DateTime? // Para certificados que caducan
  observaciones    String?
  activo           Boolean             @default(true)
  creadoEn         DateTime            @default(now())
  subidoPorId      String? // FK a Usuario — trazabilidad de quién subió

  equipo    Equipo   @relation(fields: [equipoId], references: [id], onDelete: Restrict)
  subidoPor Usuario? @relation("DocumentosSubidos", fields: [subidoPorId], references: [id], onDelete: SetNull)

  @@index([equipoId])
  @@index([tipo])
  @@index([fechaVencimiento]) // Alertas de documentos por vencer
  @@map("documentos_equipo")
}

/// Registro inmutable de cada generación de Dossier PDF por equipo.
/// Trazabilidad legal: "¿Quién descargó el expediente y en qué estado estaba el equipo?"
model DossierExportLog {
  id                     String   @id @default(uuid())
  equipoId               String
  usuarioId              String
  fechaExportacion       DateTime @default(now())
  estadoEquipoAlExportar String // Snapshot del EstadoEquipo en ese instante
  calibracionVigente     Boolean // Snapshot: ¿tenía calibración vigente?
  fueNoConforme          Boolean  @default(false) // ¿Se generó con marca de agua roja?
  jwtSnapshot            String? // HMAC-SHA256 del payload de integridad del dossier
  ipCliente              String? // IP del cliente (trazabilidad adicional)
  userAgent              String? // Dispositivo/browser del usuario

  equipo  Equipo  @relation(fields: [equipoId], references: [id], onDelete: Restrict)
  usuario Usuario @relation("DossierExports", fields: [usuarioId], references: [id], onDelete: Restrict)

  @@index([equipoId])
  @@index([usuarioId])
  @@index([fechaExportacion])
  @@map("dossier_export_logs")
}
